# ========================================
# Script Flow Environment Configuration
# ========================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# ----------------------------------------
# Supabase Configuration
# ----------------------------------------
# Get these from your Supabase project settings:
# https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api

# Supabase Project ID (from project URL)
SUPABASE_PROJECT_ID=your-project-id

# Supabase Project URL
SUPABASE_URL=https://your-project-id.supabase.co

# Supabase Publishable/Anon Key (safe for client-side)
SUPABASE_PUBLISHABLE_KEY=your-anon-key

# Supabase Service Role Key (server-side only, bypasses RLS)
# WARNING: Keep this secret! Never expose to client-side code
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ----------------------------------------
# Vite Client-Side Variables
# ----------------------------------------
# These are injected at build time by Vite
# Must be prefixed with VITE_ to be accessible in browser

VITE_SUPABASE_PROJECT_ID=your-project-id
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key

# ----------------------------------------
# AI/LLM Configuration
# ----------------------------------------

# Google Gemini API Key
# Get yours at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key
