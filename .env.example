# Salin file ini menjadi .env lalu isi dengan nilai asli dari dashboard Supabase kamu
# (Project Settings > API).

SUPABASE_URL="https://xxxxxxxxxxxx.supabase.co"
SUPABASE_PUBLISHABLE_KEY="sb_publishable_xxxxxxxxxxxxxxxxxxxx"

# Sama seperti dua di atas, tapi versi VITE_ dibaca oleh kode sisi-browser.
VITE_SUPABASE_URL="https://xxxxxxxxxxxx.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="sb_publishable_xxxxxxxxxxxxxxxxxxxx"

# Ambil dari https://aistudio.google.com/apikey — dipakai untuk fitur generate/rewrite script.
GOOGLE_API_KEY="xxxxxxxxxxxxxxxxxxxx"
